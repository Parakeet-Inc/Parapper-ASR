# cspell:words FLEURS ReazonSpeech Silero datasets en_us ja_jp jvs jvs001 jvs002 reazonspeech sherpa zipformer

# Local diagnostic dataset roots. Copy this file to .env and replace the values
# with paths on your machine. .env is ignored by git.

# JVS corpus root that contains jvs001, jvs002, ...
JVS_ROOT=.\datasets\jvs\jvs_ver1

# FLEURS-R root that contains locale directories such as ja_jp and en_us.
FLEURS_R_ROOT=.\datasets\fleurs-r

# Optional model overrides for diagnostic commands.
# If omitted, diagnostic commands resolve models from the app data models directory.
# PARAPPER_MODELS_ROOT=.\models
# PARAPPER_ASR_MODEL_DIR=.\models\sherpa-onnx-zipformer-ja-reazonspeech-2024-08-01
# PARAPPER_VAD_MODEL=.\models\silero_vad_v6\silero_vad.onnx
